# ── Required ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID — get from @userinfobot
# Multiple owners: 123456,789012
OWNER_IDS=123456789

# ── Optional ──────────────────────────────────────────────────────────────────
# How often to check all accounts (seconds). Default: 60
CHECK_INTERVAL=60

# HTTP request timeout (seconds). Default: 15
REQUEST_TIMEOUT=15
